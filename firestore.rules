rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isDev() { 
      return isAuthenticated() && 
             (request.auth.token.email == "awaishost.com@gmail.com" || 
              request.auth.token.email == "ceo+me@awaishost.com"); 
    }
    
    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USER DATA & SUBCOLLECTIONS ---
    // This recursive match captures the user document AND all sub-documents (accounts, transactions, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isDev();
    }
    
    // Explicitly allow reading/writing the user document itself
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isDev();
    }
    
    // --- WALLET TRANSFERS ---
    match /walletTransfers/{transferId} {
      // Allow list if the user is either the sender or recipient
      allow list: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isDev());
      // Allow get
      allow get: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isDev());
      // Allow creation
      allow create: if isAuthenticated() && (request.resource.data.fromUid == request.auth.uid || isDev());
      // Allow update/delete for owner/dev
      allow update, delete: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || isDev());
    }
  }
}
