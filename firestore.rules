rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isDev() { 
      return isSignedIn() && 
             (request.auth.token.email == "awaishost.com@gmail.com" || 
              request.auth.token.email == "ceo+me@awaishost.com"); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- VALIDATION HELPERS ---
    function isValidBill(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['paid', 'unpaid'] &&
             data.userId is string &&
             data.frequency in ['weekly', 'monthly', 'yearly'];
    }

    function isValidTransaction(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.amount is number && data.amount >= 0 &&
             data.type in ['income', 'expense'] &&
             data.userId is string;
    }

    // --- USERS & SUBCOLLECTIONS ---
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isDev();
      
      match /accounts/{id} {
        allow read, write: if isOwner(uid) || isDev();
      }
      
      match /transactions/{id} {
        allow read: if isOwner(uid) || isDev();
        allow create: if (isOwner(uid) || isDev()) && isValidTransaction(incoming());
        allow update: if (isOwner(uid) || isDev()) && isValidTransaction(incoming());
        allow delete: if isOwner(uid) || isDev();
      }
      
      match /bills/{id} {
        allow read: if isOwner(uid) || isDev();
        allow create: if (isOwner(uid) || isDev()) && isValidBill(incoming());
        allow update: if (isOwner(uid) || isDev()) && isValidBill(incoming());
        allow delete: if isOwner(uid) || isDev();
      }
      
      match /budgets/{id} { allow read, write: if isOwner(uid) || isDev(); }
      match /ledger/{id} { allow read, write: if isOwner(uid) || isDev(); }
      match /clients/{id} { allow read, write: if isOwner(uid) || isDev(); }
      match /staff/{id} { allow read, write: if isOwner(uid) || isDev(); }
      match /tasks/{id} { allow read, write: if isOwner(uid) || isDev(); }
      match /meetings/{id} { allow read, write: if isOwner(uid) || isDev(); }
      
      // Safety catch-all for userId matching
      match /{allSubcollections=**} {
        allow read, write: if isOwner(uid) || isDev();
      }
    }
    
    // --- WALLET TRANSFERS ---
    match /walletTransfers/{transferId} {
      allow list: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isDev());
      allow get: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isDev());
      allow create: if isSignedIn() && (incoming().fromUid == request.auth.uid || isDev());
      allow update, delete: if isDev();
    }
  }
}
