rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Basic ownership rule
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      // Subcollections (accounts, transactions, bills, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Global collections
    match /walletTransfers/{transferId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.fromUid;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
